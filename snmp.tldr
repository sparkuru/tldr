examples = []
[[hit]]
command = "snmpwalk -v 2c -c public host"
description = "扫描 host 的 snmp 信息"

[[hit]]
command = "snmpset -v2c -c public host 1.3.6.1.2.1.11.21.0 s \"value\""
description = "往 host 的 private 社区位置 1.3.6.1.2.1.11.21.0 写入一个 s 类型的 value"

