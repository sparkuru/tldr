examples = []
[[hit]]
command = "find / -perm -4000 -type f 2>/dev/null"
description = "查找设置了 SUID 位的可执行文件，常用于提权"

[[hit]]
command = "find / -uid 0 -perm -4000 -perm -0002 -type f 2>/dev/null"
description = "查找设置了 SUID 位、普通用户可写、归属于 root 的可写文件，类似 shell script 可用于提权"

